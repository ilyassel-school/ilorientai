rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Schools collection
    match /schools/{schoolId} {
      // Permettre la lecture pour tous les utilisateurs
      allow read: if true; 
      // Permettre l'écriture pour le seeding initial (à restreindre plus tard)
      allow write: if true; 
    }
    
    // Chat sessions collection
    match /chat_sessions/{sessionId} {
      // Pour le prototype, on autorise l'accès libre. 
      // En production, utiliser : allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow read, write: if true; 
    }
  }
}
